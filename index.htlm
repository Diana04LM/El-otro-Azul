<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>El Otro Azul — Antología de Escritoras</title>
    <meta name="description" content="El Otro Azul, antología de escritoras. Poesía y narrativa. Edición de Diana López.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Rye&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream:      #edeae0;
            --cream-2:    #e0ddd2;
            --blue:       #7b93c0;
            --blue-light: #b0c4dc;
            --blue-dark:  #4e6e9a;
            --navy:       #1c1e3a;
            --navy-mid:   #2d3060;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            background: var(--cream);
            color: var(--navy);
            font-family: 'Cormorant Garamond', Georgia, serif;
            overflow-x: hidden;
        }

        /* ═══════════════════════════════
           NAV
        ═══════════════════════════════ */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 50;
            display: flex; justify-content: space-between; align-items: center;
            padding: 1.1rem 4rem;
            background: rgba(237,234,224,0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(123,147,192,0.18);
        }
        .nav-brand {
            font-family: 'Rye', serif;
            font-size: 1rem;
            color: var(--navy);
            letter-spacing: 0.05em;
        }
        .nav-links { display: flex; gap: 2.5rem; list-style: none; }
        .nav-links a {
            font-family: 'Cormorant SC', serif;
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            color: var(--navy);
            text-decoration: none;
            opacity: 0.65;
            transition: opacity 0.25s, color 0.25s;
        }
        .nav-links a:hover { opacity: 1; color: var(--blue-dark); }

        /* ═══════════════════════════════
           HERO
        ═══════════════════════════════ */
        .hero {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            padding: 7rem 5rem 4rem 5rem;
            gap: 2rem;
            position: relative;
        }
        .hero::after {
            content: '';
            position: absolute;
            bottom: 0; left: -5%; right: -5%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(123,147,192,0.3), transparent);
        }
        .hero-text { z-index: 2; }

        .hero-tag {
            font-family: 'Cormorant SC', serif;
            font-size: 0.75rem;
            letter-spacing: 0.28em;
            color: var(--blue-dark);
            display: block;
            margin-bottom: 1.2rem;
            opacity: 0;
            animation: rise 0.7s 0.1s ease forwards;
        }
        .hero-title {
            font-family: 'Rye', serif;
            font-size: clamp(4.5rem, 7.5vw, 8rem);
            line-height: 0.9;
            color: var(--navy);
            margin-bottom: 2rem;
            opacity: 0;
            animation: rise 0.8s 0.25s ease forwards;
        }
        .hero-subtitle {
            font-family: 'Cormorant SC', serif;
            font-size: 0.95rem;
            letter-spacing: 0.22em;
            color: var(--blue-dark);
            margin-bottom: 0.45rem;
            opacity: 0;
            animation: rise 0.7s 0.42s ease forwards;
        }
        .hero-edition {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.9rem;
            letter-spacing: 0.1em;
            color: var(--navy);
            opacity: 0;
            margin-bottom: 3rem;
            animation: rise 0.7s 0.56s ease forwards;
        }
        .hero-cta {
            display: inline-block;
            font-family: 'Cormorant SC', serif;
            font-size: 0.78rem;
            letter-spacing: 0.22em;
            color: var(--cream);
            background: var(--navy);
            padding: 0.9rem 2.4rem;
            text-decoration: none;
            opacity: 0;
            animation: rise 0.7s 0.7s ease forwards;
            transition: background 0.3s ease, transform 0.2s ease;
        }
        .hero-cta:hover { background: var(--blue-dark); transform: translateY(-2px); }

        .hero-visual {
            display: flex; justify-content: center; align-items: center;
            opacity: 0;
            animation: rise 1s 0.35s ease forwards;
        }
        .hero-visual svg { width: 100%; max-width: 360px; height: auto; }

        @keyframes rise {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ═══════════════════════════════
           SECTION COMMON
        ═══════════════════════════════ */
        .sec-label {
            font-family: 'Cormorant SC', serif;
            font-size: 0.72rem;
            letter-spacing: 0.28em;
            color: var(--blue-dark);
            display: block;
            margin-bottom: 0.5rem;
        }
        .sec-rule {
            display: block;
            width: 36px; height: 1px;
            background: var(--blue);
            margin: 0 auto 0.8rem;
        }
        .sec-title {
            font-family: 'Rye', serif;
            font-size: 2.1rem;
            color: var(--navy);
            font-weight: 400;
        }
        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        /* ═══════════════════════════════
           AUTORAS GRID
        ═══════════════════════════════ */
        #autoras {
            padding: 7rem 5rem;
        }
        .authors-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 1.8rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .author-card {
            background: #fff;
            border: 1px solid rgba(123,147,192,0.18);
            padding: 2rem;
            cursor: pointer;
            position: relative;
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s;
        }
        .author-card::before {
            content: '';
            position: absolute;
            left: 0; top: 0; bottom: 0;
            width: 2px;
            background: var(--blue);
            transform: scaleY(0);
            transform-origin: bottom;
            transition: transform 0.35s ease;
        }
        .author-card:hover::before { transform: scaleY(1); }
        .author-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 18px 52px rgba(28,30,58,0.08);
            border-color: rgba(123,147,192,0.32);
        }
        .card-tags { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-bottom: 1.2rem; }
        .tag {
            font-family: 'Cormorant SC', serif;
            font-size: 0.66rem;
            letter-spacing: 0.15em;
            color: var(--blue-dark);
            background: rgba(123,147,192,0.1);
            border: 1px solid rgba(123,147,192,0.25);
            padding: 0.18rem 0.6rem;
        }
        .card-name {
            font-family: 'Rye', serif;
            font-size: 1.3rem;
            color: var(--navy);
            font-weight: 400;
            margin-bottom: 0.22rem;
        }
        .card-origin {
            font-style: italic;
            font-size: 0.88rem;
            opacity: 0.5;
            margin-bottom: 1.2rem;
        }
        .card-excerpt {
            font-style: italic;
            font-size: 0.98rem;
            line-height: 1.75;
            opacity: 0.72;
            border-left: 2px solid var(--blue-light);
            padding-left: 1rem;
            margin-bottom: 1.5rem;
        }
        .card-leer {
            font-family: 'Cormorant SC', serif;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            color: var(--blue-dark);
            display: flex; align-items: center; gap: 0.5rem;
        }
        .card-leer span { display: inline-block; transition: transform 0.22s ease; }
        .author-card:hover .card-leer span { transform: translateX(6px); }

        /* ═══════════════════════════════
           PANEL (slide-in)
        ═══════════════════════════════ */
        .overlay {
            position: fixed; inset: 0;
            background: rgba(28,30,58,0.45);
            z-index: 100;
            opacity: 0; pointer-events: none;
            transition: opacity 0.4s ease;
            backdrop-filter: blur(4px);
        }
        .overlay.open { opacity: 1; pointer-events: all; }

        .panel {
            position: fixed;
            top: 0; right: -110%; bottom: 0;
            width: min(660px, 100vw);
            background: var(--cream);
            z-index: 101;
            overflow-y: auto;
            transition: right 0.52s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .panel.open { right: 0; }

        .panel-top {
            position: sticky; top: 0;
            background: var(--cream);
            border-bottom: 1px solid rgba(123,147,192,0.18);
            padding: 1.1rem 2.5rem;
            display: flex; justify-content: flex-end;
            z-index: 10;
        }
        .panel-cerrar {
            font-family: 'Cormorant SC', serif;
            font-size: 0.73rem;
            letter-spacing: 0.14em;
            color: var(--navy);
            background: none;
            border: 1px solid rgba(123,147,192,0.32);
            padding: 0.48rem 1.1rem;
            cursor: pointer;
            transition: background 0.22s, border-color 0.22s;
        }
        .panel-cerrar:hover {
            background: rgba(123,147,192,0.12);
            border-color: var(--blue);
        }

        .panel-body { padding: 2.5rem; }

        .panel-name {
            font-family: 'Rye', serif;
            font-size: 2.1rem;
            color: var(--navy);
            font-weight: 400;
            line-height: 1.05;
            margin-bottom: 0.3rem;
        }
        .panel-origin {
            font-style: italic;
            color: var(--blue-dark);
            font-size: 1rem;
            margin-bottom: 1.8rem;
        }
        .panel-bio {
            font-size: 1.05rem;
            line-height: 1.88;
            opacity: 0.82;
            padding-bottom: 2.5rem;
            border-bottom: 1px solid rgba(123,147,192,0.2);
            margin-bottom: 2.5rem;
        }

        .text-piece { margin-bottom: 3rem; }
        .text-tipo {
            font-family: 'Cormorant SC', serif;
            font-size: 0.68rem;
            letter-spacing: 0.22em;
            color: var(--blue-dark);
            display: block;
            margin-bottom: 0.3rem;
        }
        .text-titulo {
            font-family: 'Rye', serif;
            font-size: 1.2rem;
            color: var(--navy);
            font-weight: 400;
            margin-bottom: 1.3rem;
        }
        .text-cuerpo {
            font-size: 1.05rem;
            line-height: 1.92;
            color: var(--navy);
        }
        .text-cuerpo.poesia {
            font-style: italic;
            white-space: pre-wrap;
        }
        .text-cuerpo p { margin-bottom: 1.2em; }
        .text-sep {
            text-align: center;
            letter-spacing: 0.4em;
            color: var(--blue);
            opacity: 0.5;
            margin: 2.2rem 0;
        }

        /* ═══════════════════════════════
           SOBRE
        ═══════════════════════════════ */
        #sobre {
            padding: 7rem 5rem;
            background: var(--navy);
            color: var(--cream);
            position: relative;
            overflow: hidden;
        }
        #sobre::before {
            content: '';
            position: absolute;
            right: -8%; top: -40%;
            width: 55%; height: 180%;
            background: var(--blue);
            opacity: 0.055;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
        }
        .sobre-inner {
            max-width: 680px;
            margin: 0 auto;
            text-align: center;
            position: relative;
        }
        .sobre-inner .sec-label  { color: var(--blue-light); }
        .sobre-inner .sec-rule   { background: var(--blue-light); opacity: 0.5; }
        .sobre-inner .sec-title  { color: var(--cream); margin-bottom: 2rem; }
        .sobre-text {
            font-size: 1.12rem;
            line-height: 1.95;
            opacity: 0.8;
        }

        /* ═══════════════════════════════
           FOOTER
        ═══════════════════════════════ */
        footer {
            background: var(--navy);
            border-top: 1px solid rgba(123,147,192,0.1);
            padding: 1.8rem 5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .footer-brand {
            font-family: 'Rye', serif;
            font-size: 0.88rem;
            color: var(--blue-light);
            opacity: 0.85;
        }
        .footer-info {
            font-family: 'Cormorant SC', serif;
            font-size: 0.7rem;
            letter-spacing: 0.14em;
            color: var(--cream);
            opacity: 0.3;
        }

        /* ═══════════════════════════════
           RESPONSIVE
        ═══════════════════════════════ */
        @media (max-width: 820px) {
            nav { padding: 1rem 1.5rem; }
            .nav-links { gap: 1.5rem; }
            .hero {
                grid-template-columns: 1fr;
                padding: 6rem 1.8rem 3rem;
                text-align: center;
            }
            .hero-visual { order: -1; }
            .hero-visual svg { max-width: 200px; }
            .hero-cta { margin: 0 auto; display: block; max-width: 200px; text-align: center; }
            #autoras, #sobre { padding: 5rem 1.8rem; }
            footer { flex-direction: column; gap: 0.5rem; text-align: center; padding: 1.5rem; }
            .panel-body { padding: 1.5rem; }
        }
    </style>
</head>
<body>

<!-- ══ NAV ══════════════════════════════ -->
<nav>
    <span class="nav-brand">El Otro Azul</span>
    <ul class="nav-links">
        <li><a href="#autoras">Autoras</a></li>
        <li><a href="#sobre">Sobre</a></li>
    </ul>
</nav>

<!-- ══ HERO ═════════════════════════════ -->
<section class="hero">
    <div class="hero-text">
        <span class="hero-tag">Antología de Escritoras</span>
        <h1 class="hero-title">El<br>Otro<br>Azul</h1>
        <p class="hero-subtitle">Poesía · Narrativa</p>
        <p class="hero-edition">Edición de Diana López</p>
        <a href="#autoras" class="hero-cta">Explorar autoras</a>
    </div>
    <div class="hero-visual">
        <!-- Silueta inspirada en la portada -->
        <svg viewBox="0 0 300 490" xmlns="http://www.w3.org/2000/svg">
            <!-- Chongo / moño -->
            <ellipse cx="86" cy="86" rx="36" ry="27" fill="#7b93c0" transform="rotate(-22 86 86)"/>
            <ellipse cx="68" cy="72" rx="21" ry="17" fill="#7b93c0" transform="rotate(-38 68 72)"/>
            <ellipse cx="56" cy="58" rx="15" ry="12" fill="#7b93c0" transform="rotate(-50 56 58)"/>
            <!-- Silueta de perfil femenino -->
            <path d="
                M 112 46
                C 132 30, 170 26, 204 44
                C 230 58, 244 87, 242 118
                C 240 138, 230 152, 233 168
                C 236 183, 242 193, 236 210
                C 228 228, 212 236, 207 253
                C 202 270, 206 287, 202 307
                C 198 327, 193 348, 198 373
                C 202 396, 208 416, 194 437
                L 300 490
                L 0 490
                C 10 462, 32 440, 54 420
                C 74 402, 88 386, 90 362
                C 93 338, 83 316, 78 292
                C 73 265, 70 240, 78 216
                C 84 198, 94 186, 96 168
                C 98 148, 88 126, 84 102
                C 80 74, 91 52, 112 46
                Z
            " fill="#7b93c0"/>
        </svg>
    </div>
</section>

<!-- ══ AUTORAS ═══════════════════════════ -->
<section id="autoras">
    <div class="section-header">
        <span class="sec-label">El Archivo</span>
        <span class="sec-rule"></span>
        <h2 class="sec-title">Autoras</h2>
    </div>
    <div class="authors-grid" id="authorsGrid"></div>
</section>

<!-- ══ SOBRE ═════════════════════════════ -->
<section id="sobre">
    <div class="sobre-inner">
        <span class="sec-label">Acerca del proyecto</span>
        <span class="sec-rule"></span>
        <h2 class="sec-title">Sobre la antología</h2>
        <!-- EDITA este texto con tu presentación real de la antología -->
        <p class="sobre-text">
            <em>El Otro Azul</em> reúne voces de escritoras contemporáneas en los géneros de poesía y narrativa breve. Un archivo vivo de escritura que desborda los márgenes, que nombra lo que no tiene nombre todavía. Cada texto aquí es una puerta hacia el mundo interior de estas autoras y hacia el mundo compartido que sus palabras construyen.
        </p>
    </div>
</section>

<!-- ══ FOOTER ════════════════════════════ -->
<footer>
    <span class="footer-brand">El Otro Azul</span>
    <span class="footer-info">Antología de Escritoras · Edición de Diana López</span>
</footer>

<!-- ══ PANEL (detalle de autora) ═════════ -->
<div class="overlay" id="overlay"></div>
<aside class="panel" id="panel" role="dialog" aria-modal="true" aria-label="Perfil de autora">
    <div class="panel-top">
        <button class="panel-cerrar" id="closeBtn">Cerrar ✕</button>
    </div>
    <div class="panel-body" id="panelBody"></div>
</aside>

<script>
/* ══════════════════════════════════════════════════
   DATOS DE LAS AUTORAS
   ─────────────────────────────────────────────────
   Cada autora tiene:
     · nombre    → nombre completo tal como aparecerá
     · origen    → ciudad, país, fechas u otro dato
     · generos   → arreglo con "Poesía" y/o "Narrativa"
     · bio       → nota biográfica (párrafo de texto)
     · textos    → arreglo de textos, cada uno con:
         - tipo      → "Poesía" o "Cuento"
         - titulo    → título del texto
         - cuerpo    → el texto completo
         - esPoesia  → true para poemas, false para prosa

   Para agregar una autora, copia uno de los bloques
   entre llaves { } separado por comas.
══════════════════════════════════════════════════ */
const autoras = [
    {
        nombre: "Nombre de la Primera Autora",
        origen: "Ciudad, País",
        generos: ["Poesía"],
        bio: "Aquí va la nota biográfica de la autora. Puedes incluir su lugar de nacimiento, formación, publicaciones anteriores, premios y cualquier dato relevante sobre su trayectoria. Una o dos oraciones es suficiente, o puedes escribir más.",
        textos: [
            {
                tipo: "Poesía",
                titulo: "Título del poema",
                cuerpo: `Aquí van los versos del poema,
cada línea en su propio renglón,
el ritmo que la autora eligió
para decir lo que no cabe en prosa.

Una segunda estrofa
puede seguir aquí,
con el blanco que respira
entre cada pausa.`,
                esPoesia: true
            }
        ]
    },
    {
        nombre: "Nombre de la Segunda Autora",
        origen: "Ciudad, País",
        generos: ["Narrativa"],
        bio: "Nota biográfica de la segunda autora. Contexto literario, publicaciones, dónde vive y escribe, qué temas le importan y cómo llegó a la escritura.",
        textos: [
            {
                tipo: "Cuento",
                titulo: "Título del cuento",
                cuerpo: `Aquí empieza el texto en prosa. Puedes pegar el cuento completo tal como aparece en la antología. El sitio lo mostrará con buena tipografía y espacio generoso.

Un segundo párrafo puede seguir aquí. Los saltos de línea dobles se convierten automáticamente en nuevos párrafos, así que puedes escribir con naturalidad.`,
                esPoesia: false
            }
        ]
    },
    {
        nombre: "Nombre de la Tercera Autora",
        origen: "Ciudad, País",
        generos: ["Poesía", "Narrativa"],
        bio: "Esta autora trabaja en los dos géneros de la antología. Una voz que cruza la imagen poética y la narración, construyendo un mundo propio en cada texto.",
        textos: [
            {
                tipo: "Poesía",
                titulo: "Primer poema",
                cuerpo: `Un primer poema,
breve y certero,
que abre la lectura.`,
                esPoesia: true
            },
            {
                tipo: "Cuento",
                titulo: "Un texto en prosa",
                cuerpo: `Un texto narrativo que acompaña los poemas. La alternancia de géneros muestra la amplitud de esta autora.

La historia puede continuar aquí, con todos sus párrafos.`,
                esPoesia: false
            }
        ]
    }
];

/* ── Utilidad: extracto para la tarjeta ── */
function extracto(autora) {
    const lineas = autora.textos[0].cuerpo.trim().split('\n').slice(0, 3).join(' ');
    const palabras = lineas.split(/\s+/).slice(0, 20).join(' ');
    return palabras + '…';
}

/* ── Render de tarjetas ── */
function renderGrid() {
    const grid = document.getElementById('authorsGrid');
    grid.innerHTML = autoras.map((a, i) => `
        <article
            class="author-card"
            onclick="abrirPanel(${i})"
            tabindex="0"
            onkeydown="if(event.key==='Enter')abrirPanel(${i})"
            role="button"
            aria-label="Ver textos de ${a.nombre}"
        >
            <div class="card-tags">
                ${a.generos.map(g => `<span class="tag">${g}</span>`).join('')}
            </div>
            <h3 class="card-name">${a.nombre}</h3>
            <p class="card-origin">${a.origen}</p>
            <blockquote class="card-excerpt">${extracto(a)}</blockquote>
            <div class="card-leer">Leer textos <span>→</span></div>
        </article>
    `).join('');
}

/* ── Render del cuerpo del texto ── */
function renderCuerpo(texto) {
    if (texto.esPoesia) {
        return `<div class="text-cuerpo poesia">${escapeHtml(texto.cuerpo)}</div>`;
    }
    const parrafos = texto.cuerpo.split(/\n\n+/).map(p => `<p>${escapeHtml(p.replace(/\n/g, ' '))}</p>`).join('');
    return `<div class="text-cuerpo">${parrafos}</div>`;
}

function escapeHtml(str) {
    return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

/* ── Abrir panel ── */
function abrirPanel(i) {
    const a = autoras[i];
    document.getElementById('panelBody').innerHTML = `
        <div class="card-tags" style="margin-bottom:1.2rem">
            ${a.generos.map(g => `<span class="tag">${g}</span>`).join('')}
        </div>
        <h2 class="panel-name">${a.nombre}</h2>
        <p class="panel-origin">${a.origen}</p>
        <p class="panel-bio">${escapeHtml(a.bio)}</p>
        <div>
            ${a.textos.map((t, j) => `
                ${j > 0 ? '<div class="text-sep">· · ·</div>' : ''}
                <div class="text-piece">
                    <span class="text-tipo">${t.tipo}</span>
                    <h3 class="text-titulo">${t.titulo}</h3>
                    ${renderCuerpo(t)}
                </div>
            `).join('')}
        </div>
    `;
    document.getElementById('panel').classList.add('open');
    document.getElementById('overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    document.getElementById('panel').scrollTop = 0;
}

/* ── Cerrar panel ── */
function cerrarPanel() {
    document.getElementById('panel').classList.remove('open');
    document.getElementById('overlay').classList.remove('open');
    document.body.style.overflow = '';
}

document.getElementById('closeBtn').addEventListener('click', cerrarPanel);
document.getElementById('overlay').addEventListener('click', cerrarPanel);
document.addEventListener('keydown', e => { if (e.key === 'Escape') cerrarPanel(); });

/* ── Inicializar ── */
renderGrid();
</script>

</body>
</html>
